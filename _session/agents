#!/usr/bin/env python3
"""
agents — unified dispatcher for LIVE agent sessions (grok, composer, codex, gemini).

Addresses any engine by a stable handle, the way Claude Code messages a named subagent:

  agents start  <engine> --handle H [--model M] [--cwd DIR] [--full-auto]
  agents send   --to H [--bg] [<text> | -]      # text arg or stdin; foreground blocks until turn-end
  agents read   --to H [--turn N]
  agents status --to H
  agents list
  agents stop   --to H
  agents gc     [--days N]

Sessions live under /tmp/agent_sessions/<handle>/ (own namespace; one-shot /tmp/<skill>_runs untouched).
Control channel: the daemon's unix socket, with an inbox/ file-drop fallback.
"""
import argparse, fcntl, json, os, re, shutil, socket, subprocess, sys, threading, time

# default to a PER-USER path (not the shared /tmp/agent_sessions) so another local user can't pre-create
# or read this user's sessions; _ensure_base_dir() locks it down to 0700 + own-uid.
BASE_DIR = os.environ.get("AGENT_SESSIONS_DIR", f"/tmp/agent_sessions-{os.getuid()}")
DAEMON = os.path.join(os.path.dirname(os.path.abspath(__file__)), "session_daemon.py")
STARTUP_TIMEOUT = int(os.environ.get("SESSION_STARTUP_TIMEOUT", "180"))
STALE_SEC = int(os.environ.get("SESSION_STALE_SEC", "90"))
LIVE_STATES = ("starting", "idle", "busy")
DEFAULT_MODEL = {"grok": "grok-build", "composer": "grok-composer-2.5-fast",
                 "codex": "gpt-5.5", "gemini": "Gemini 3.5 Flash (High)"}


_HANDLE_RE = re.compile(r'^[A-Za-z0-9][A-Za-z0-9_.-]*$')


def sdir(handle):
    # a handle is a SINGLE path component of safe chars — never a path that could escape BASE_DIR
    # (a traversal handle would make cmd_start's rmtree delete an arbitrary directory).
    if not handle or not _HANDLE_RE.match(handle):
        print(f"invalid handle '{handle}': use letters/digits/_/-/. starting alphanumeric (no '/')",
              file=sys.stderr)
        sys.exit(2)
    d = os.path.join(BASE_DIR, handle)
    if os.path.dirname(os.path.realpath(d)) != os.path.realpath(BASE_DIR):
        print(f"handle '{handle}' escapes the sessions dir", file=sys.stderr)
        sys.exit(2)
    return d


def read_file(p, default=""):
    try:
        with open(p) as f:
            return f.read().strip()
    except Exception:
        return default


def pid_alive(pid):
    try:
        os.kill(int(pid), 0)
        return True
    except Exception:
        return False


def session_status(d):
    """Return (status, stale_bool). Mirrors the watchdog stale-sweep: a LIVE status whose daemon.log
    is older than STALE_SEC AND whose wd_pid is dead == a zombie."""
    st = read_file(os.path.join(d, "status"), "unknown")
    if st in LIVE_STATES:
        log = os.path.join(d, "daemon.log")
        wd = read_file(os.path.join(d, "wd_pid"))
        try:
            age = time.time() - os.path.getmtime(log)
        except OSError:
            age = 1e9
        if age > STALE_SEC and (not wd or not pid_alive(wd)):
            return st, True
    return st, False


# --------------------------------------------------------------------------- control channel
class _ConnectError(Exception):
    """Connect-stage failure: the request was NEVER sent, so the inbox fallback is safe (no dup turn)."""


def _sock_request(d, req, timeout):
    sp = os.path.join(d, "control.sock")
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.settimeout(timeout)
    try:
        s.connect(sp)
    except OSError as e:
        s.close()
        raise _ConnectError(str(e))
    # connected: from here we do NOT auto-retry — the daemon may have received the request, and an
    # inbox replay would run the turn twice.
    try:
        s.sendall((json.dumps(req) + "\n").encode())
        data = b""
        while b"\n" not in data:
            chunk = s.recv(65536)
            if not chunk:
                break
            data += chunk
    finally:
        s.close()
    if not data or b"\n" not in data:
        raise RuntimeError("daemon closed the control socket without a full response (turn state unknown)")
    return json.loads(data.decode().splitlines()[0])


def _inbox_request(d, req, timeout):
    """Fallback used ONLY when the socket isn't listening yet (startup race): atomic drop, poll reply,
    and bail if the daemon's wd_pid dies."""
    inbox = os.path.join(d, "inbox")
    os.makedirs(inbox, exist_ok=True)
    name = f"req-{int(time.time()*1000)}-{os.getpid()}"
    tmp = os.path.join(inbox, name + ".json.tmp")
    with open(tmp, "w") as f:
        json.dump(req, f)
    os.replace(tmp, os.path.join(inbox, name + ".json"))   # atomic: daemon never sees a partial file
    reply = os.path.join(inbox, name + ".reply")
    wd = read_file(os.path.join(d, "wd_pid"))
    deadline = time.time() + timeout
    while time.time() < deadline:
        if os.path.exists(reply):
            with open(reply) as f:
                r = json.load(f)
            try:
                os.unlink(reply)
            except Exception:
                pass
            return r
        if wd and not pid_alive(wd):
            raise ConnectionError("daemon is not running")
        time.sleep(0.3)
    raise TimeoutError("inbox request timed out")


def control(d, req, timeout=920):
    try:
        return _sock_request(d, req, timeout)
    except _ConnectError:
        return _inbox_request(d, req, timeout)


# --------------------------------------------------------------------------- commands
def _clear_for_resume(d):
    """Clear only the volatile runtime files so a fresh daemon starts clean, but PRESERVE session.txt
    (the native conversation id we reattach to) + meta.json."""
    for nm in ("status", "control.sock", "pid", "wd_pid", "daemon.log", "launch.log",
               "stderr.log", "turns.jsonl"):
        try:
            os.unlink(os.path.join(d, nm))
        except FileNotFoundError:
            pass
        except Exception:
            pass
    for sub in ("outbox", "inbox"):
        shutil.rmtree(os.path.join(d, sub), ignore_errors=True)


def _ensure_base_dir():
    """Create BASE_DIR private to this user (0700) and refuse a pre-existing one owned by someone else —
    a shared /tmp path is otherwise a local hijack/DoS surface."""
    try:
        if os.path.isdir(BASE_DIR):
            st = os.stat(BASE_DIR)
            if st.st_uid != os.getuid():
                print(f"refusing: {BASE_DIR} is owned by uid {st.st_uid}, not you ({os.getuid()}); "
                      f"set AGENT_SESSIONS_DIR to a private path", file=sys.stderr)
                sys.exit(2)
            if st.st_mode & 0o077:
                os.chmod(BASE_DIR, 0o700)      # tighten any group/world bits (umask) on our own dir
        else:
            os.makedirs(BASE_DIR, mode=0o700, exist_ok=True)
    except SystemExit:
        raise
    except Exception:
        pass


def _handle_lock(handle):
    """An flock-held file serializing concurrent `start` of the SAME handle, so two racing starts can't
    both see a just-launched (pre-wd_pid) session as stale and rmtree it. Caller closes it to release."""
    lockdir = os.path.join(BASE_DIR, ".locks")
    os.makedirs(lockdir, exist_ok=True)
    lf = open(os.path.join(lockdir, handle + ".lock"), "w")
    fcntl.flock(lf, fcntl.LOCK_EX)
    return lf


def cmd_start(a):
    d = sdir(a.handle)
    lock = _handle_lock(a.handle)            # serialize same-handle starts through the claim
    resume_id = ""
    meta = {}
    model = ""
    try:
        if getattr(a, "resume", False):
            # reattach to a prior conversation: keep session.txt + meta, restart the daemon with --resume-id
            if not os.path.isdir(d):
                print(f"--resume: no existing session '{a.handle}' to resume", file=sys.stderr)
                return 2
            st, stale = session_status(d)
            wd = read_file(os.path.join(d, "wd_pid"))
            if st in LIVE_STATES and not stale and bool(wd) and pid_alive(wd):
                print(f"--resume: '{a.handle}' is still live (status={st}); `agents stop` it first", file=sys.stderr)
                return 2
            resume_id = read_file(os.path.join(d, "session.txt"))
            if not resume_id:
                print(f"--resume: '{a.handle}' has no saved conversation id to reattach to", file=sys.stderr)
                return 2
            try:
                meta = json.loads(read_file(os.path.join(d, "meta.json"), "{}"))
            except Exception:
                meta = {}
            saved_engine = meta.get("engine")
            if saved_engine and saved_engine != a.engine:
                print(f"--resume: '{a.handle}' is a {saved_engine} session; run "
                      f"`agents start {saved_engine} --handle {a.handle} --resume`", file=sys.stderr)
                return 2
            _clear_for_resume(d)
        elif os.path.isdir(d):
            st, stale = session_status(d)
            wd = read_file(os.path.join(d, "wd_pid"))
            wd_dead = bool(wd) and not pid_alive(wd)   # a just-killed daemon has a fresh log but a dead pid
            if st in LIVE_STATES and not stale and not wd_dead:
                print(f"handle '{a.handle}' already live (status={st}) at {d}", file=sys.stderr)
                return 2
            # dead or stale handle: clear the old session dir so the name can be reused
            shutil.rmtree(d, ignore_errors=True)
        os.makedirs(d, exist_ok=True)
        model = a.model or meta.get("model") or DEFAULT_MODEL.get(a.engine, "")
        cwd = meta.get("cwd") if (resume_id and meta.get("cwd")) else os.path.abspath(a.cwd)
        full_auto = a.full_auto or bool(meta.get("full_auto"))
        argv = [sys.executable, DAEMON, d, "--engine", a.engine, "--model", model, "--cwd", cwd]
        if full_auto:
            argv.append("--full-auto")
        if resume_id:
            argv += ["--resume-id", resume_id]
        launch_log = open(os.path.join(d, "launch.log"), "ab")
        try:
            subprocess.Popen(argv, stdin=subprocess.DEVNULL, stdout=launch_log, stderr=launch_log,
                             start_new_session=True, close_fds=True)
        finally:
            launch_log.close()
        # hold the lock until the daemon CLAIMS the handle (writes wd_pid), so a concurrent same-handle
        # start can't see this just-launched (pre-wd_pid) session as stale and rmtree it out from under us
        claim_deadline = time.time() + 15
        while time.time() < claim_deadline:
            if read_file(os.path.join(d, "wd_pid")):
                break
            if read_file(os.path.join(d, "status"), "") in ("failed", "aborted", "stopped", "done"):
                break
            time.sleep(0.1)
    finally:
        try:
            fcntl.flock(lock, fcntl.LOCK_UN); lock.close()
        except Exception:
            pass
    # wait for the daemon to leave 'starting' (lock released — the handle is already claimed)
    deadline = time.time() + STARTUP_TIMEOUT
    while time.time() < deadline:
        st = read_file(os.path.join(d, "status"), "starting")
        if st == "idle":
            out = {"handle": a.handle, "engine": a.engine, "model": model,
                   "status": "idle", "session_dir": d,
                   "session_id": read_file(os.path.join(d, "session.txt"))}
            if resume_id:
                out["resumed"] = True       # only on resume -> a plain start stays byte-identical to round 1
            print(json.dumps(out))
            return 0
        if st in ("failed", "aborted", "stopped", "done"):
            print(f"session failed to start (status={st}). See {d}/daemon.log + {d}/stderr.log", file=sys.stderr)
            return 1
        time.sleep(0.4)
    print(f"timed out waiting for session to become ready (last status={st})", file=sys.stderr)
    return 1


def _resolve_text(a):
    if a.text == "-" or a.text is None:
        return sys.stdin.read()
    return a.text


def _load_schema_into(req, schema_path):
    if schema_path:
        with open(schema_path) as f:
            req["schema"] = json.load(f)   # may raise; the caller turns it into a clear error


def _fanout_targets(a):
    """Live sessions to broadcast to: all of them, optionally filtered to --engines."""
    want = set(e.strip() for e in a.engines.split(",") if e.strip()) if a.engines else None
    targets = []
    if not os.path.isdir(BASE_DIR):
        return targets
    for h in sorted(os.listdir(BASE_DIR)):
        if h.startswith("."):
            continue                            # skip .board and other non-session dirs
        d = os.path.join(BASE_DIR, h)
        if not os.path.isdir(d):
            continue
        st, stale = session_status(d)
        wd = read_file(os.path.join(d, "wd_pid"))
        if stale or st not in ("idle", "busy", "starting") or (wd and not pid_alive(wd)):
            continue
        if want is not None:
            meta = {}
            try:
                meta = json.loads(read_file(os.path.join(d, "meta.json"), "{}"))
            except Exception:
                pass
            if meta.get("engine") not in want:
                continue
        targets.append((h, d))
    return targets


def _cmd_send_fanout(a):
    """Broadcast the same text to every live target IN PARALLEL (thread per target, failures isolated)."""
    base = {"op": "send", "bg": bool(a.bg)}
    if getattr(a, "from_", None):
        base["from"] = a.from_
    if getattr(a, "schema", None):
        try:
            _load_schema_into(base, a.schema)
        except Exception as e:
            print(f"--schema: cannot read/parse '{a.schema}': {e}", file=sys.stderr)
            return 2
    targets = _fanout_targets(a)
    if not targets:
        print(json.dumps({}))
        print("no live target sessions matched", file=sys.stderr)
        return 1
    text = _resolve_text(a)
    results = {}
    lock = threading.Lock()
    def worker(h, d):
        req = dict(base); req["text"] = text
        try:
            resp = control(d, req)
        except Exception as e:
            resp = {"ok": False, "error": str(e)}
        with lock:
            results[h] = resp
    ths = [threading.Thread(target=worker, args=(h, d), daemon=True) for h, d in targets]
    for t in ths:
        t.start()
    deadline = time.time() + int(os.environ.get("SESSION_HANG_SEC", "900")) + 60   # ONE global deadline
    for t in ths:
        t.join(timeout=max(0.0, deadline - time.time()))
    out = {}
    for h, _d in targets:
        r = results.get(h, {"ok": False, "error": "no response (timed out)"})
        if r.get("ok"):
            out[h] = {"turn": r.get("turn"), "status": r.get("status")} if a.bg else {"reply": r.get("reply")}
        else:
            out[h] = {"error": r.get("error")}
    print(json.dumps(out, indent=2))
    return 0 if any(results.get(h, {}).get("ok") for h, _ in targets) else 1


def cmd_send(a):
    if getattr(a, "to_all", False) or getattr(a, "engines", None):
        return _cmd_send_fanout(a)
    if not a.to:
        print("send: provide --to H (or --to-all / --engines to broadcast)", file=sys.stderr)
        return 2
    d = sdir(a.to)
    if not os.path.isdir(d):
        print(f"no such session '{a.to}'", file=sys.stderr)
        return 2
    st, stale = session_status(d)
    wd = read_file(os.path.join(d, "wd_pid"))
    if stale or st in ("done", "failed", "hung_killed", "aborted", "stopped", "cancelled") or (wd and not pid_alive(wd)):
        print(f"session '{a.to}' is not live (status={st}{', stale' if stale else ''})", file=sys.stderr)
        return 1
    text = _resolve_text(a)
    req = {"op": "send", "text": text, "bg": bool(a.bg)}
    if getattr(a, "from_", None):
        req["from"] = a.from_
    if getattr(a, "schema", None):
        try:
            with open(a.schema) as f:
                req["schema"] = json.load(f)
        except Exception as e:
            print(f"--schema: cannot read/parse '{a.schema}': {e}", file=sys.stderr)
            return 2
    try:
        resp = control(d, req)
    except Exception as e:
        print(f"send failed: {e}", file=sys.stderr)
        return 1
    if not resp.get("ok"):
        print(f"send failed: {resp.get('error')}", file=sys.stderr)
        return 1
    if a.bg:
        print(json.dumps({"handle": a.to, "turn": resp.get("turn"), "status": resp.get("status")}))
        return 0
    sys.stdout.write(resp.get("reply") or "")
    if not (resp.get("reply") or "").endswith("\n"):
        sys.stdout.write("\n")
    return 0


def cmd_cancel(a):
    d = sdir(a.to)
    if not os.path.isdir(d):
        print(f"no such session '{a.to}'", file=sys.stderr)
        return 2
    st, stale = session_status(d)
    wd = read_file(os.path.join(d, "wd_pid"))
    if stale or st in ("done", "failed", "hung_killed", "aborted", "stopped", "cancelled") or (wd and not pid_alive(wd)):
        print(f"session '{a.to}' is not live (status={st})", file=sys.stderr)
        return 1
    try:
        resp = control(d, {"op": "cancel"}, timeout=60)
    except Exception as e:
        print(f"cancel failed: {e}", file=sys.stderr)
        return 1
    print(json.dumps(resp))
    return 0 if resp.get("ok") else 1


_TOPIC_RE = re.compile(r'^[A-Za-z0-9][A-Za-z0-9_.-]*$')


def _board_topic_path(topic):
    """A topic is a single safe filename under BASE_DIR/.board/ (never an escaping path)."""
    if not topic or not _TOPIC_RE.match(topic):
        raise ValueError(f"invalid topic '{topic}': letters/digits/_/-/. only, no '/'")
    bd = os.path.join(BASE_DIR, ".board")
    os.makedirs(bd, exist_ok=True)
    return os.path.join(bd, topic + ".jsonl")


def cmd_board(a):
    """Shared append-only blackboard for agent-to-agent coordination (full-auto agents run this too)."""
    sub = getattr(a, "board_cmd", None)
    if sub == "post":
        try:
            path = _board_topic_path(a.topic)
        except ValueError as e:
            print(str(e), file=sys.stderr)
            return 2
        msg = a.msg
        if msg is None or msg == "-":
            msg = sys.stdin.read()
        import fcntl
        with open(path, "a+") as f:
            fcntl.flock(f, fcntl.LOCK_EX)        # atomic seq + append under an exclusive lock
            try:
                f.seek(0)
                n = sum(1 for _ in f) + 1
                rec = {"n": n, "ts": int(time.time()), "from": a.from_, "msg": msg}
                f.write(json.dumps(rec) + "\n")
                f.flush()
            finally:
                fcntl.flock(f, fcntl.LOCK_UN)
        print(json.dumps({"topic": a.topic, "n": n, "from": a.from_}))
        return 0
    if sub == "read":
        try:
            path = _board_topic_path(a.topic)
        except ValueError as e:
            print(str(e), file=sys.stderr)
            return 2
        out = []
        if os.path.exists(path):
            import fcntl
            with open(path) as f:
                fcntl.flock(f, fcntl.LOCK_SH)    # shared lock: never read a line mid-write
                try:
                    for line in f:
                        line = line.strip()
                        if not line:
                            continue
                        try:
                            rec = json.loads(line)
                        except Exception:
                            continue
                        if rec.get("n", 0) > (a.since or 0):
                            out.append(rec)
                finally:
                    fcntl.flock(f, fcntl.LOCK_UN)
        print(json.dumps(out, indent=2))
        return 0
    print('board: `agents board post --topic T --from H "msg"` or `agents board read --topic T [--since N]`',
          file=sys.stderr)
    return 2


def _outbox_turn_nums(outdir):
    nums = set()
    if os.path.isdir(outdir):
        for nm in os.listdir(outdir):
            base = None
            if nm.endswith(".md"):
                base = nm[:-3]
            elif nm.endswith(".partial"):
                base = nm[:-len(".partial")]
            if base is not None:
                try:
                    nums.add(int(base))
                except ValueError:
                    pass
    return nums


def _follow_turn(d, n):
    """Stream outbox/<n>.partial live (printing only the newly-appended suffix; gemini rewrites the
    file with a growing snapshot, grok/codex append — both stay a growing prefix), then print the
    authoritative outbox/<n>.md when it appears. Bails out if the session goes terminal first."""
    outdir = os.path.join(d, "outbox")
    partial = os.path.join(outdir, f"{n}.partial")
    final = os.path.join(outdir, f"{n}.md")
    shown = ""
    deadline = time.time() + int(os.environ.get("SESSION_HANG_SEC", "900")) + 60
    while time.time() < deadline:
        if os.path.exists(final):
            break
        cur = read_file(partial, "")
        if cur != shown:
            if cur.startswith(shown) and len(cur) > len(shown):
                sys.stdout.write(cur[len(shown):]); sys.stdout.flush(); shown = cur   # grew: print the new suffix
            elif cur and not shown.startswith(cur):
                sys.stdout.write("\n" + cur); sys.stdout.flush(); shown = cur          # genuinely diverged: reprint
            # else: cur is a prefix of shown or empty -> a transient truncation (gemini rewrites in place); ignore
        st, stale = session_status(d)
        if (stale or st in ("failed", "hung_killed", "aborted", "stopped")) and not os.path.exists(final):
            sys.stdout.write(f"\n(turn {n} ended without a final reply; status={st}{', stale' if stale else ''})\n")
            return 1
        time.sleep(0.2)
    final_text = read_file(final, "")
    sys.stdout.write(final_text[len(shown):] if final_text.startswith(shown) else ("\n" if shown else "") + final_text)
    if not final_text.endswith("\n"):
        sys.stdout.write("\n")
    return 0


def cmd_read(a):
    d = sdir(a.to)
    if not os.path.isdir(d):
        print(f"no such session '{a.to}'", file=sys.stderr)
        return 2
    outdir = os.path.join(d, "outbox")
    if getattr(a, "follow", False):
        n = a.turn
        if not n:
            # wait briefly for an in-flight turn to register (e.g. `send --bg` then immediate `read --follow`)
            for _ in range(25):
                nums = _outbox_turn_nums(outdir)
                if nums:
                    n = max(nums)
                    break
                time.sleep(0.2)
            if not n:
                print("(no turns yet)", file=sys.stderr)
                return 1
        return _follow_turn(d, n)
    if a.turn:
        f = os.path.join(outdir, f"{a.turn}.md")
    else:
        outs = sorted(int(nm[:-3]) for nm in (os.listdir(outdir) if os.path.isdir(outdir) else []) if nm.endswith(".md"))
        if not outs:
            print("(no turns yet)", file=sys.stderr)
            return 1
        f = os.path.join(outdir, f"{outs[-1]}.md")
    sys.stdout.write(read_file(f) + "\n")
    return 0


def cmd_status(a):
    d = sdir(a.to)
    if not os.path.isdir(d):
        print(f"no such session '{a.to}'", file=sys.stderr)
        return 2
    st, stale = session_status(d)
    meta = {}
    try:
        meta = json.loads(read_file(os.path.join(d, "meta.json"), "{}"))
    except Exception:
        pass
    print(json.dumps({
        "handle": a.to, "status": st + (" (stale)" if stale else ""),
        "engine": meta.get("engine"), "model": meta.get("model"), "kind": meta.get("kind"),
        "session_id": read_file(os.path.join(d, "session.txt")),
        "turns": sum(1 for _ in open(os.path.join(d, "turns.jsonl"))) if os.path.exists(os.path.join(d, "turns.jsonl")) else 0,
        "session_dir": d,
    }, indent=2))
    return 0


def cmd_list(a):
    if not os.path.isdir(BASE_DIR):
        print("(no sessions)")
        return 0
    rows = []
    for h in sorted(os.listdir(BASE_DIR)):
        if h.startswith("."):
            continue                    # .board and other non-session dirs
        d = os.path.join(BASE_DIR, h)   # iterating existing dirs; do not re-validate the name
        if not os.path.isdir(d):
            continue
        st, stale = session_status(d)
        meta = {}
        try:
            meta = json.loads(read_file(os.path.join(d, "meta.json"), "{}"))
        except Exception:
            pass
        rows.append((h, meta.get("engine", "?"), st + (" (stale)" if stale else "")))
    if not rows:
        print("(no sessions)")
        return 0
    w = max(len(r[0]) for r in rows)
    for h, eng, st in rows:
        print(f"  {h:<{w}}  {eng:<9}  {st}")
    return 0


def cmd_stop(a):
    d = sdir(a.to)
    if not os.path.isdir(d):
        print(f"no such session '{a.to}'", file=sys.stderr)
        return 2
    st, stale = session_status(d)
    if stale or st not in LIVE_STATES:
        # already dead; just report
        print(f"session '{a.to}' not live (status={st})")
        return 0
    try:
        control(d, {"op": "stop"}, timeout=15)
    except Exception as e:
        print(f"stop signal failed ({e}); session may already be exiting", file=sys.stderr)
    print(f"stopped '{a.to}'")
    return 0


def cmd_gc(a):
    if not os.path.isdir(BASE_DIR):
        return 0
    cutoff = time.time() - a.days * 86400
    removed = 0
    import shutil
    for h in os.listdir(BASE_DIR):
        if h.startswith("."):
            continue                    # never sweep .board (the shared blackboard)
        d = os.path.join(BASE_DIR, h)   # iterating existing dirs; do not re-validate the name
        if not os.path.isdir(d):
            continue
        st, stale = session_status(d)
        dead = stale or st not in LIVE_STATES   # also sweeps "unknown"/empty/corrupt status
        try:
            old = os.path.getmtime(os.path.join(d, "daemon.log")) < cutoff
        except OSError:
            old = True
        if dead and old:
            shutil.rmtree(d, ignore_errors=True)
            removed += 1
    print(f"gc: removed {removed} dead/old session(s)")
    return 0


def main():
    ap = argparse.ArgumentParser(prog="agents")
    sub = ap.add_subparsers(dest="cmd", required=True)

    p = sub.add_parser("start"); p.add_argument("engine", choices=["grok", "composer", "codex", "gemini"])
    p.add_argument("--handle", required=True); p.add_argument("--model", default="")
    p.add_argument("--cwd", default=os.getcwd()); p.add_argument("--full-auto", action="store_true")
    p.add_argument("--resume", action="store_true", help="reattach to this handle's saved conversation id")
    p.set_defaults(fn=cmd_start)

    p = sub.add_parser("send"); p.add_argument("--to", default=None)
    p.add_argument("text", nargs="?", default=None); p.add_argument("--bg", action="store_true")
    p.add_argument("--schema", default=None, help="path to a JSON Schema file; reply is JSON validated against it")
    p.add_argument("--to-all", dest="to_all", action="store_true", help="broadcast to ALL live sessions")
    p.add_argument("--engines", default=None, help="broadcast to live sessions of these engines (comma list)")
    p.add_argument("--from", dest="from_", default=None, help="sender tag recorded on the turn (a2a)")
    p.set_defaults(fn=cmd_send)

    p = sub.add_parser("read"); p.add_argument("--to", required=True); p.add_argument("--turn", type=int)
    p.add_argument("--follow", action="store_true", help="stream the turn's live partial until it finalizes")
    p.set_defaults(fn=cmd_read)

    p = sub.add_parser("cancel"); p.add_argument("--to", required=True); p.set_defaults(fn=cmd_cancel)
    bp = sub.add_parser("board")
    bs = bp.add_subparsers(dest="board_cmd")
    bpost = bs.add_parser("post"); bpost.add_argument("--topic", default="default")
    bpost.add_argument("--from", dest="from_", default="?"); bpost.add_argument("msg", nargs="?", default=None)
    bread = bs.add_parser("read"); bread.add_argument("--topic", default="default")
    bread.add_argument("--since", type=int, default=0)
    bp.set_defaults(fn=cmd_board)
    p = sub.add_parser("status"); p.add_argument("--to", required=True); p.set_defaults(fn=cmd_status)
    p = sub.add_parser("list"); p.set_defaults(fn=cmd_list)
    p = sub.add_parser("stop"); p.add_argument("--to", required=True); p.set_defaults(fn=cmd_stop)
    p = sub.add_parser("gc"); p.add_argument("--days", type=int, default=7); p.set_defaults(fn=cmd_gc)

    a = ap.parse_args()
    _ensure_base_dir()       # private 0700 sessions dir; refuse a foreign-owned shared path
    return a.fn(a)


if __name__ == "__main__":
    sys.exit(main())
